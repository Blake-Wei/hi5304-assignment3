{
  "name": "HI5304 Python + Postgres + RStudio",
  "dockerComposeFile": ["../docker-compose.yml"],
  "service": "app",
  "runServices": ["db"],
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {},
    "ghcr.io/devcontainers/features/apt-packages:1": {
      "packages": "postgresql-client"
    },

    "ghcr.io/rocker-org/devcontainer-features/r-apt:0": {},
    "ghcr.io/rocker-org/devcontainer-features/rstudio-server:0": {}
  },

  "forwardPorts": [8787],
  "portsAttributes": {
    "8787": { "label": "RStudio Server" }
  },

  "postCreateCommand": "sudo bash -lc 'echo \"vscode:hi5304\" | chpasswd'",

  "postAttachCommand": "sudo bash -lc '(rserver || true)'"
}











